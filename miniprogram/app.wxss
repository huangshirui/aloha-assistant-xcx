/**app.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
} 

button {
  background: initial;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}


page {
  /* Surface Hierarchy (Light Default) */
  --surface: #f8f9fa;
  --surface-container-lowest: #ffffff;
  --surface-container-low: #f1f4f5;
  --surface-container: #edf1f3;
  --surface-container-high: #ffffff;
  --surface-container-highest: #e5eaee;
  --surface-bright: #ffffff;
  --surface-variant: rgba(255, 255, 255, 0.7);
  
  /* Colors */
  --primary: #1a1c2e;
  --primary-container: #2b2e4a;
  --primary-fixed-dim: #457B9D;
  --secondary-container: #edf1f3;
  --on-secondary-container: #1a1c2e;
  --tertiary: #457B9D;
  
  /* Text & Strokes */
  --on-surface: #1a1c2e;
  --outline: rgba(26, 28, 46, 0.12);
  --outline-variant: rgba(26, 28, 46, 0.06);
  --surface-tint: #457B9D;
  --icon-filter: brightness(0) invert(0);

  /* Spacing */
  --spacing-6: 1.5rem; /* 24px */
  --spacing-8: 2rem; /* 32px */

  background: var(--surface);
  color: var(--on-surface);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

@media (prefers-color-scheme: dark) {
  page {
    /* Surface Hierarchy (Dark Override) */
    --surface: #0b0e14;
    --surface-container-lowest: #000000;
    --surface-container-low: #10131a;
    --surface-container: #151820;
    --surface-container-high: #1c2028;
    --surface-container-highest: #222630;
    --surface-bright: #282c36;
    --surface-variant: rgba(28, 32, 40, 0.4);
    
    /* Colors */
    --primary: #8ff5ff;
    --primary-container: #00eefc;
    --primary-fixed-dim: #32a7b8;
    --secondary-container: #1e293b;
    --on-secondary-container: #ecedf6;
    --tertiary: #65afff;
    
    /* Text & Strokes */
    --on-surface: #ecedf6;
    --outline: rgba(143, 245, 255, 0.2);
    --outline-variant: rgba(143, 245, 255, 0.15);
    --surface-tint: #8ff5ff;
    --icon-filter: brightness(0) invert(1);
  }
}

/* Typography Classes */
.display-lg {
  font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
  font-size: 3.5rem;
  font-weight: 700;
  line-height: indulgence;
}

.headline-md {
  font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
  font-size: 1.75rem;
  font-weight: 600;
}

.title-lg {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 1.375rem;
  font-weight: 500;
}

.body-lg {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 1rem;
  font-weight: 400;
}

.label-md {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
}

.rounded-full {
  border-radius: 9999px;
}