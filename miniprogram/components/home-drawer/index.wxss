.drawer-shell {
  position: fixed;
  inset: 0;
  z-index: 20;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8rpx);
}

.drawer-panel {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 476rpx;
  padding: 120rpx 28rpx 44rpx;
  box-sizing: border-box;
  background: var(--surface-container-low);
  box-shadow: 16rpx 0 60rpx rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
}

.drawer-panel__header {
  margin-bottom: 28rpx;
}

.drawer-panel__title {
  font-family: 'Inter', sans-serif;
  font-size: 20rpx;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(236, 237, 246, 0.38);
}

.drawer-panel__entry {
  padding: 24rpx 12rpx;
  border-radius: 24rpx;
}

.drawer-panel__entry-label {
  font-family: 'Inter', sans-serif;
  font-size: 32rpx;
  color: var(--on-surface);
}

.drawer-panel__footer {
  margin-top: auto;
  padding: 22rpx 16rpx;
  border-radius: 28rpx;
  background: var(--surface-container-high);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.drawer-panel__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: var(--surface-container-lowest);
  font-family: 'Inter', sans-serif;
  font-size: 28rpx;
  font-weight: 600;
}

.drawer-panel__user {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.drawer-panel__name {
  font-family: 'Inter', sans-serif;
  font-size: 26rpx;
  color: var(--on-surface);
  font-weight: 500;
}

.drawer-panel__meta {
  font-family: 'Inter', sans-serif;
  font-size: 20rpx;
  color: rgba(236, 237, 246, 0.44);
}
