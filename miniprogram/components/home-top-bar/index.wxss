.top-bar {
  position: relative;
  z-index: 5;
  box-sizing: border-box;
}

.top-bar__safe {
  width: 100%;
}

.top-bar__nav {
  position: relative;
  width: 100%;
}

.menu-button {
  position: absolute;
  left: 16px;
  margin: 0;
  padding: 0;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.menu-button--pressed {
  background: rgba(255, 255, 255, 0.24);
}

.menu-icon-image {
  width: 22px;
  height: 22px;
  filter: var(--icon-filter);
}

.brand-block {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 260px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  pointer-events: none;
}

.brand-block__title {
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 1.375rem;
  line-height: 1.1;
  font-weight: 500;
  letter-spacing: -0.04em;
  color: var(--on-surface);
}

.brand-block__dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.brand-block__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.3;
  animation: pulse 1.5s infinite ease-in-out;
}

.brand-block__dot--delay {
  animation-delay: 0.3s;
}

.brand-block__dot--late {
  animation-delay: 0.6s;
}

@keyframes pulse {
  0%, 100% { 
    opacity: 0.3; 
    transform: scale(1); 
  }
  50% { 
    opacity: 1; 
    transform: scale(1.2); 
    box-shadow: 0 0 6px var(--primary); 
  }
}

.capsule-spacer {
  position: absolute;
}
