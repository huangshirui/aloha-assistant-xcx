.overlay-shell {
  position: fixed;
  left: 42rpx;
  right: 42rpx;
  bottom: 246rpx;
  z-index: 13;
}

.overlay-panel {
  width: 100%;
  border-radius: 36rpx;
  background: var(--surface-variant);
  box-shadow: 0 28rpx 60rpx rgba(0, 0, 0, 0.4), inset 0 0 0 1rpx var(--outline-variant);
  backdrop-filter: blur(24rpx);
}

.overlay-panel__action {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  margin: 12rpx;
  border-radius: 24rpx;
}

.overlay-panel__icon-wrap {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-bright);
}

.overlay-panel__icon {
  width: 30rpx;
  height: 30rpx;
  filter: var(--icon-filter);
}

.overlay-panel__label {
  font-family: 'Inter', sans-serif;
  font-size: 24rpx;
  color: var(--on-surface);
}
