.canvas {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  border-radius: 44rpx 44rpx 0 0;
  background: linear-gradient(180deg, rgba(241, 244, 245, 0.88) 0%, rgba(239, 243, 246, 0.96) 100%);
  overflow: hidden;
}

.canvas__wash {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 12%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 36%);
}

.canvas__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(48rpx);
  opacity: 0.7;
}

.canvas__glow--primary {
  width: 420rpx;
  height: 420rpx;
  left: 50%;
  top: 45%;
  transform: translate(-50%, -50%);
  background: rgba(133, 169, 192, 0.16);
}

.canvas__glow--secondary {
  width: 520rpx;
  height: 260rpx;
  left: 50%;
  bottom: 120rpx;
  transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.58);
}

.canvas__stage {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 24rpx 36rpx 0;
}

.canvas__item {
  display: flex;
  justify-content: center;
}

.canvas__card {
  width: 100%;
  max-width: 620rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow:
    0 38rpx 88rpx rgba(26, 28, 46, 0.08),
    0 8rpx 18rpx rgba(26, 28, 46, 0.04);
}

.canvas__card--welcome {
  margin: 180rpx 24rpx 180rpx;
  padding: 58rpx 42rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.canvas__card--assistant {
  margin: 92rpx 0 48rpx;
  padding: 36rpx 34rpx;
}

.canvas__icon-orb {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  margin-bottom: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 247, 249, 0.98) 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(26, 28, 46, 0.04),
    0 10rpx 26rpx rgba(26, 28, 46, 0.08);
}

.canvas__icon {
  width: 50rpx;
  height: 50rpx;
}

.canvas__title {
  font-size: 64rpx;
  line-height: 1.08;
  text-align: center;
  color: #1a1c2e;
  font-weight: 650;
  letter-spacing: -0.04em;
}

.canvas__subtitle {
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  text-align: center;
  color: rgba(26, 28, 46, 0.68);
  white-space: pre-wrap;
}

.canvas__chips {
  margin-top: 52rpx;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 18rpx;
}

.canvas__chip {
  min-width: 184rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #edf1f3;
  color: #1a1c2e;
  font-size: 22rpx;
  line-height: 1;
  text-align: center;
}

.canvas__eyebrow {
  font-size: 18rpx;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(26, 28, 46, 0.38);
}

.canvas__assistant-text {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #1a1c2e;
  white-space: pre-wrap;
}

.canvas__card-title {
  font-size: 34rpx;
  color: #1a1c2e;
  font-weight: 600;
}

.canvas__card-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(26, 28, 46, 0.62);
}
