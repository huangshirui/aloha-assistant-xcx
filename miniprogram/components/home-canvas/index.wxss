.canvas {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  border-radius: 48rpx 48rpx 0 0;
  background: transparent;
  overflow: hidden;
}

.canvas__wash {
  position: absolute;
  inset: 0;
  background: transparent;
}

.canvas__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(48rpx);
  opacity: 0.15;
}

.canvas__glow--primary {
  width: 420rpx;
  height: 420rpx;
  left: 50%;
  top: 45%;
  transform: translate(-50%, -50%);
  background: var(--primary);
}

.canvas__glow--secondary {
  width: 520rpx;
  height: 260rpx;
  left: 50%;
  bottom: 120rpx;
  transform: translateX(-50%);
  background: var(--primary-container);
}

.canvas__stage {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 24rpx 36rpx 0;
}

.canvas__item {
  display: flex;
  justify-content: center;
}

.canvas__card {
  width: 100%;
  max-width: 620rpx;
  border-radius: 48rpx;
  background: linear-gradient(180deg, var(--surface-container-low) 0%, var(--surface-container-highest) 100%);
  box-shadow: inset 0 0 0 1rpx var(--outline-variant);
}

.canvas__card--welcome {
  margin: 180rpx 24rpx 180rpx;
  padding: 58rpx 42rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.canvas__card--assistant {
  margin: 92rpx 0 48rpx;
  padding: 36rpx 34rpx;
}

.canvas__icon-orb {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  margin-bottom: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-bright);
  box-shadow: inset 0 0 0 1rpx var(--outline-variant);
}

.canvas__icon {
  width: 50rpx;
  height: 50rpx;
  filter: var(--icon-filter);
}

.canvas__title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 64rpx;
  line-height: 1.08;
  text-align: center;
  color: var(--on-surface);
  font-weight: 700;
  letter-spacing: -0.04em;
}

.canvas__subtitle {
  font-family: 'Inter', sans-serif;
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  text-align: center;
  color: rgba(236, 237, 246, 0.68);
  white-space: pre-wrap;
}

.canvas__chips {
  margin-top: 52rpx;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 18rpx;
}

.canvas__chip {
  min-width: 184rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--surface-container-high);
  color: var(--on-surface);
  font-family: 'Inter', sans-serif;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
  font-weight: 600;
  transition: background 0.2s ease, transform 0.2s ease;
}

.canvas__chip-hover {
  background: var(--surface-bright);
  transform: translateY(-2px);
}

.canvas__eyebrow {
  font-family: 'Inter', sans-serif;
  font-size: 20rpx;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(236, 237, 246, 0.38);
}

.canvas__assistant-text {
  font-family: 'Inter', sans-serif;
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--on-surface);
  white-space: pre-wrap;
}

.canvas__card-title {
  font-family: 'Inter', sans-serif;
  font-size: 34rpx;
  color: var(--on-surface);
  font-weight: 600;
}

.canvas__card-subtitle {
  font-family: 'Inter', sans-serif;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(236, 237, 246, 0.62);

}
