.toolbar-shell {
  position: fixed;
  left: 42rpx;
  right: 42rpx;
  bottom: 76rpx;
  z-index: 14;
}

.toolbar-surface {
  overflow: hidden;
  border-radius: 66rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow:
    0 24rpx 60rpx rgba(26, 28, 46, 0.11),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.58);
  backdrop-filter: blur(30rpx);
}

.toolbar-surface--expanded {
  background: rgba(255, 255, 255, 0.98);
}

.toolbar-composer {
  padding: 26rpx 26rpx 18rpx;
}

.toolbar-composer__field {
  min-height: 232rpx;
}

.toolbar-composer__textarea {
  width: 100%;
  min-height: 204rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #1a1c2e;
}

.toolbar-composer__textarea::placeholder {
  color: rgba(26, 28, 46, 0.28);
}

.toolbar-composer__actions {
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: space-between !important;
}

.toolbar-composer__leading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-composer__icon-button {
  width: 76rpx !important;
  height: 76rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 999rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  box-sizing: border-box;
  flex-shrink: 0;
  min-width: 76rpx;
  min-height: 76rpx;
}

.toolbar-composer__icon-button--soft {
  background: rgba(246, 248, 250, 0.92);
}

.toolbar-composer__icon {
  width: 34rpx;
  height: 34rpx;
}

.toolbar-composer__send {
  width: 76rpx !important;
  height: 76rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 999rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  background: #666a84 !important;
  box-shadow: 0 16rpx 30rpx rgba(26, 28, 46, 0.14) !important;
  margin-left: auto !important;
  flex-shrink: 0 !important;
}

.toolbar-composer__send-icon {
  width: 28rpx;
  height: 28rpx;
}

.toolbar-divider {
  padding: 0 14rpx;
}

.toolbar-divider__line {
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(26, 28, 46, 0.07);
}

.toolbar {
  height: 148rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
}

.toolbar__item {
  width: 108rpx;
  height: 108rpx;
  margin: 0;
  padding: 0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 180ms ease;
}

.toolbar__item--active {
  background: rgba(247, 249, 251, 0.95);
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.46),
    0 10rpx 24rpx rgba(26, 28, 46, 0.05);
}

.toolbar__item--strong {
  background: rgba(247, 249, 251, 0.98);
  box-shadow:
    inset 0 0 0 2rpx rgba(102, 106, 132, 0.12),
    0 12rpx 26rpx rgba(26, 28, 46, 0.08);
}

.toolbar__icon {
  width: 42rpx;
  height: 42rpx;
  opacity: 0.72;
}

.toolbar__icon--active {
  opacity: 1;
  transform: scale(1.04);
  filter: drop-shadow(0 0 1px rgba(69, 123, 157, 0.24));
}
