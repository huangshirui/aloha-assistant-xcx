.toolbar-shell {
  position: fixed;
  left: 42rpx;
  right: 42rpx;
  bottom: 76rpx;
  z-index: 10;
}

.more-panel {
  margin-left: auto;
  margin-bottom: 24rpx;
  width: 232rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow:
    0 28rpx 60rpx rgba(26, 28, 46, 0.12),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24rpx);
}

.more-panel__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 14rpx;
  border-radius: 22rpx;
}

.more-panel__item:active {
  background: rgba(237, 241, 243, 0.8);
}

.more-panel__icon-wrap {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f5f6;
}

.more-panel__icon {
  width: 30rpx;
  height: 30rpx;
}

.more-panel__label {
  font-size: 24rpx;
  color: #1a1c2e;
}

.toolbar {
  height: 154rpx;
  padding: 0 18rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(231, 236, 240, 0.8);
  box-shadow:
    0 28rpx 70rpx rgba(26, 28, 46, 0.14),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.42);
  backdrop-filter: blur(28rpx);
}

.toolbar__item {
  width: 108rpx;
  height: 108rpx;
  margin: 0;
  padding: 0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 180ms ease;
}

.toolbar__item--active {
  background: rgba(255, 255, 255, 0.28);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.32);
}

.toolbar__icon {
  width: 42rpx;
  height: 42rpx;
}
