.toolbar-shell {
  position: fixed;
  left: 42rpx;
  right: 42rpx;
  bottom: 76rpx;
  z-index: 14;
}

.toolbar-surface {
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--surface-variant);
  box-shadow: 0 40rpx 80rpx rgba(143, 245, 255, 0.05); /* 20px -> 40rpx, 40px -> 80rpx */
  backdrop-filter: blur(32px);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.toolbar-surface--expanded {
  border-radius: 66rpx;
  background: var(--surface-container-high);
  box-shadow: 0 0 0 2rpx var(--outline), 0 40rpx 80rpx rgba(143, 245, 255, 0.05);
}

.toolbar-composer {
  padding: 26rpx 26rpx 18rpx;
}

.toolbar-composer__field {
  min-height: 232rpx;
}

.toolbar-composer__textarea {
  width: 100%;
  min-height: 204rpx;
  font-family: 'Inter', sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  color: var(--on-surface);
}

.toolbar-composer__textarea::placeholder {
  color: rgba(236, 237, 246, 0.28);
}

.toolbar-composer__actions {
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: space-between !important;
}

.toolbar-composer__leading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-composer__icon-button {
  width: 76rpx !important;
  height: 76rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 999rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  box-sizing: border-box;
  flex-shrink: 0;
  min-width: 76rpx;
  min-height: 76rpx;
}

.toolbar-composer__icon-button--soft {
  background: var(--surface-bright);
}

.toolbar-composer__icon {
  width: 34rpx;
  height: 34rpx;
  filter: var(--icon-filter);
}

.toolbar-composer__send {
  width: 76rpx !important;
  height: 76rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 999rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  background: linear-gradient(135deg, var(--primary), var(--primary-container)) !important;
  box-shadow: 0 16rpx 30rpx rgba(143, 245, 255, 0.14) !important;
  margin-left: auto !important;
  flex-shrink: 0 !important;
}

.toolbar-composer__send-icon {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(0); /* Make sure icon inside primary button is dark */
}

.toolbar-divider {
  padding: 0 14rpx;
}

.toolbar-divider__line {
  height: 2rpx;
  border-radius: 999rpx;
  background: var(--outline-variant);
}

.toolbar {
  height: 148rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
}

.toolbar__item {
  width: 108rpx;
  height: 108rpx;
  margin: 0;
  padding: 0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 180ms ease;
}

.toolbar__item--active {
  background: linear-gradient(135deg, var(--primary), var(--primary-container));
  box-shadow: 0 10rpx 24rpx rgba(143, 245, 255, 0.2);
}

.toolbar__item--strong {
  background: var(--surface-bright);
  box-shadow: inset 0 0 0 1rpx var(--outline-variant);
}

.toolbar__icon {
  width: 42rpx;
  height: 42rpx;
  opacity: 0.72;
  filter: var(--icon-filter);
}

.toolbar__icon--active {
  opacity: 1;
  transform: scale(1.04);
  filter: brightness(0) invert(0); /* Black icon on primary gradient */
}
