page {
  height: 100%;
  background: var(--surface);
}

.home-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--surface);
  color: var(--on-surface);
  overflow: hidden;
}

.home-page::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 72%, rgba(143, 245, 255, 0.05) 0%, rgba(143, 245, 255, 0) 40%);
  pointer-events: none;
}

.home-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  padding: 0;
  box-sizing: border-box;
}

home-canvas {
  width: 100%;
  height: 100%;
}
