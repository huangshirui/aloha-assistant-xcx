page {
  height: 100%;
  background: linear-gradient(180deg, #fcfbf8 0%, #f3f5f6 56%, #e5eaee 100%);
}

.home-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0) 30%),
    linear-gradient(180deg, #fcfbf8 0%, #f4f6f6 58%, #dce3e7 100%);
  color: #1a1c2e;
  overflow: hidden;
}

.home-page::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 72%, rgba(69, 123, 157, 0.09) 0%, rgba(69, 123, 157, 0) 28%);
  pointer-events: none;
}

.home-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  padding: 0 24rpx 228rpx;
  box-sizing: border-box;
}
