<view class="home-page">
  <home-top-bar
    metrics="{{navMetrics}}"
    status-text="{{topBar.text}}"
    status-mode="{{topBar.mode}}"
    bind:menutap="handleMenuTap"
  />

  <view class="home-shell">
    <home-canvas canvas-items="{{canvasItems}}" bind:prompttap="handlePromptTap" />
  </view>

  <home-overlay-panel
    panel-state="{{ui.panelState}}"
    more-actions="{{moreActions}}"
    bind:moreaction="handleMoreAction"
  />

  <home-toolbar
    toolbar-visual="{{toolbarVisual}}"
    panel-state="{{ui.panelState}}"
    composer="{{ui.composer}}"
    voice="{{ui.voice}}"
    bind:toolchange="handleToolChange"
    bind:voiceholdstart="handleVoiceHoldStart"
    bind:voiceholdend="handleVoiceHoldEnd"
    bind:composerinput="handleComposerInput"
    bind:composersubmit="handleComposerSubmit"
  />

  <home-drawer
    open="{{ui.panelState.drawerOpen}}"
    entries="{{drawerEntries}}"
    user="{{user}}"
    bind:drawerclose="handleDrawerClose"
    bind:drawerselect="handleDrawerSelect"
  />
</view>
